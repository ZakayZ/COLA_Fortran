#ifndef COLA_FORTRAN_@CLASS_NAME@_WRITER_HH
#define COLA_FORTRAN_@CLASS_NAME@_WRITER_HH

#include <memory>

#include <COLA.hh>
#include <COLA_Fortran/FortranUtil.hh>

namespace cola::fortran {
    // NOLINTBEGIN(readability-identifier-naming)
    extern "C" {
        /** Create writer instance. Returns opaque handle. \p params is ParametersMap* (vector of pair<string,string>). */
        void* cola_fortran_@CLASS_NAME@_create(const void* params);

        /** Write one event. \p data is EventData* (read-only from C++ side). */
        void cola_fortran_@CLASS_NAME@_run(void* handle, void* data);

        /** Destroy writer instance and release resources for \p handle. */
        void cola_fortran_@CLASS_NAME@_destroy(void* handle);
    }
    // NOLINTEND(readability-identifier-naming)

    class @CLASS_NAME@ : public VWriterFactory {
        @CLASS_NAME@() = default;

        std::unique_ptr<VFilter> Create(const std::unordered_map<std::string, std::string>& metaData) override;

        const std::string& GetFilterName() const override {
            return "@CLASS_NAME@";
        }
    };

} // namespace cola::fortran

#endif // COLA_FORTRAN_@CLASS_NAME@_WRITER_HH
