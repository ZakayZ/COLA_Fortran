#include "@MODULE_NAME@/@CLASS_NAME@.hh"

#include <COLA_Fortran/utils.hh>

// NOLINTBEGIN(readability-identifier-naming)
extern "C" {
    void* cola_fortran_@CLASS_NAME@_create(const void* params, char** errorMessage);

    void cola_fortran_@CLASS_NAME@_run(void* handle, void* data, char** errorMessage);

    void cola_fortran_@CLASS_NAME@_destroy(void* handle);
}
// NOLINTEND(readability-identifier-naming)

namespace cola::fortran {
    using FortranConverter = GenericFortranConverter<
        cola_fortran_@CLASS_NAME@_create,
        cola_fortran_@CLASS_NAME@_destroy,
        cola_fortran_@CLASS_NAME@_run
    >;

    std::unique_ptr<cola::VFilter> @CLASS_NAME@Factory::Create(const std::unordered_map<std::string, std::string>& metaData) {
        return std::make_unique<FortranConverter>(metaData);
    }
} // namespace cola::fortran
