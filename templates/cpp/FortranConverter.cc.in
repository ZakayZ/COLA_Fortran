#include "@CLASS_NAME@.hh"

namespace cola::fortran {
    class FortranConverter : public VConverter {
    public:
        FortranConverter(const std::unordered_map<std::string, std::string>& params)
            : handle_(cola_fortran_@CLASS_NAME@_create(ToFortranParametersMap(params).data()), cola_fortran_@CLASS_NAME@_destroy) {}

        ~FortranConverter() = default;

        std::unique_ptr<EventData> operator()(std::unique_ptr<EventData>&& data) override {
            cola_fortran_@CLASS_NAME@_run(handle_.get(), data.get());
            return data;
        }

    private:
        std::unique_ptr<void, void (*)(void*)> handle_;
    };

    std::unique_ptr<VFilter> @CLASS_NAME@::Create(const std::unordered_map<std::string, std::string>& metaData) override {
        return std::make_unique<FortranConverter>(metaData);
    }
} // namespace cola::fortran
