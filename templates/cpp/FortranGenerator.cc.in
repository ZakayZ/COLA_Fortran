#include "@MODULE_NAME@/@CLASS_NAME@.hh"

#include <COLA_Fortran/utils.hh>

// NOLINTBEGIN(readability-identifier-naming)
extern "C" {
void* cola_fortran_@CLASS_NAME@_create(const void* params, char** error_message);

void* cola_fortran_@CLASS_NAME@_run(void* handle, char** error_message);

void cola_fortran_@CLASS_NAME@_destroy(void* handle);
}
// NOLINTEND(readability-identifier-naming)

namespace cola::fortran {
using FortranGenerator =
    GenericFortranGenerator<cola_fortran_@CLASS_NAME@_create, cola_fortran_@CLASS_NAME@_destroy, cola_fortran_@CLASS_NAME@_run>;

std::unique_ptr<cola::VFilter> @CLASS_NAME@Factory::Create(
    const std::unordered_map<std::string, std::string>& meta_data) {
  return std::make_unique<FortranGenerator>(meta_data);
}

}  // namespace cola::fortran
