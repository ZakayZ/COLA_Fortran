#include "@CLASS_NAME@.hh"

namespace cola::fortran {

    class FortranGenerator : public VGenerator {
    public:
        FortranGenerator(const std::unordered_map<std::string, std::string>& params)
            : handle_(cola_fortran_@CLASS_NAME@_create(ToFortranParametersMap(params).data()), cola_fortran_@CLASS_NAME@_destroy) {}

        ~FortranGenerator() = default;

        std::unique_ptr<EventData> operator()() override {
            void* raw = cola_fortran_@CLASS_NAME@_run(handle_.get());
            return std::unique_ptr<EventData>(static_cast<EventData*>(raw));
        }

    private:
        std::unique_ptr<void, void (*)(void*)> handle_;
    };

    std::unique_ptr<VFilter> @CLASS_NAME@::Create(const std::unordered_map<std::string, std::string>& metaData) override {
        return std::make_unique<FortranGenerator>(metaData);
    }

} // namespace cola::fortran
